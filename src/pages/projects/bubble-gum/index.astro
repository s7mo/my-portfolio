---
import ProjectDetail from '../../../components/ProjectDetail.astro';
const base = import.meta.env.BASE_URL;
---

<ProjectDetail
  title="Gumball Machine"
  subtitle="woodworking + mechanism fabrication"
  date="April 2022 – May 2022"
  images={[
    { src: `${base}images/portfolio-docx/image12.png`, alt: 'Assembled gumball machine' },
    { src: `${base}images/portfolio-docx/image13.png`, alt: 'Gumball machine parts layout' },
  ]}
  what={[
    'Fabricated a fully functional gumball distributing machine made almost entirely out of wood.',
    'Built for real handling, reassembly, and practical use.',
  ]}
  how={[
    'Used woodworking machinery to fabricate and finish major components.',
    'Assembled and tuned the dispensing mechanism for smooth operation.',
    'Applied food-grade wood finish for practical use.',
  ]}
  results={[
    'Delivered finished assembly with documented part layout and build story.',
  ]}
/>
