---
import Layout from '../../components/Layout.astro';

const base = import.meta.env.BASE_URL;
const arm = `${base}images/RobotArm Images`;
const buster = `${base}images/MegaBuster Images`;
const can = `${base}images/Can Crusher Toy Images`;
---

<style>
  h1 {
    text-align: left;
    font-size: 60px;
    margin-bottom: 1rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2.25rem;
  }

  .project-card {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0.9rem;
    background: rgba(220, 220, 255, 0.08);
    border: 2px solid var(--nav-border);
    border-radius: 18px;
    padding: 1.25rem;
    text-align: left;
    box-shadow: 10px 10px 0 var(--link-color);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    cursor: pointer;
    color: inherit;
    text-decoration: none;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 8px 8px 0 var(--link-hover);
    border-color: var(--link-hover);
  }

  .project-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    border-radius: 14px;
    border: 2px solid rgba(255, 255, 255, 0.10);
    background: rgba(0, 0, 0, 0.12);
  }

  .project-card h3 {
    margin: 0.5rem 0;
    color: var(--link-color);
    font-size: 1.35rem;
  }

  .project-card p {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.9;
    margin: 0;
    line-height: 1.45;
  }

  @media (max-width: 520px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .project-card {
      box-shadow: 7px 7px 0 var(--link-color);
    }
  }
</style>

<Layout title="projects">
  <section class="section">
    <h1><b>projects</b></h1>

    <div class="projects-grid">
      <a href={`${base}projects/benchy-mover`} class="project-card">
        <img src={`${arm}/111.png`} alt="Benchy Mover (4DOF arm) preview" />
        <h3>Benchy Mover (4DOF arm)</h3>
        <p>
          ME380 team project: move 3D Benchies with constraints on precision, dexterity, and
          strength-to-weight—full portfolio and PDF on the project page.
        </p>
      </a>

      <a href={`${base}projects/robot-arm`} class="project-card">
        <img src={`${arm}/1.JPG`} alt="ASTROBRA project cover" />
        <h3>ASTROBRA</h3>
        <p>4-axis arm with user arm tracking and computer-vision gesture control.</p>
      </a>

      <a href={`${base}projects/mega-man-buster-toy`} class="project-card">
        <img src={`${buster}/11.jpg`} alt="Mega Man Buster Toy preview" />
        <h3>Mega Man Buster Toy</h3>
        <p>Ping-pong launching Mega Buster with free-fire and charge-up modes (WIP).</p>
      </a>

      <a href={`${base}projects/guitar-robot`} class="project-card">
        <img src={`${base}images/portfolio-docx/image3.png`} alt="Guitar playing robot project cover" />
        <h3>Guitar Playing Robot</h3>
        <p>Electromechanical build for automated strumming on a real guitar.</p>
      </a>

      <a href={`${base}projects/can-crusher`} class="project-card">
        <img src={`${can}/7.jpeg`} alt="Can crusher project cover" />
        <h3>Can Crusher</h3>
        <p>Hydraulic/pneumatic can crusher + zipline toy—designed, built, and showcased.</p>
      </a>

      <a href={`${base}projects/bubble-gum`} class="project-card">
        <img src={`${base}images/portfolio-docx/image12.png`} alt="Gumball machine project cover" />
        <h3>Gumball Machine</h3>
        <p>Wood-built, food-finish gumball dispenser—functional and fully assembled.</p>
      </a>
    </div>
  </section>
</Layout>
