---
import ProjectDetail from '../../../components/ProjectDetail.astro';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<ProjectDetail
  title="Guitar Playing Robot"
  subtitle="electromechanical build"
  date="March 2023 – April 2023"
  images={[
    { src: `${base}images/portfolio-docx/image3.png`, alt: 'Guitar robot full setup' },
    { src: `${base}images/portfolio-docx/image4.png`, alt: 'Guitar robot strumming close-up' },
  ]}
  what={[
    'Built a robotic mechanism to play a guitar using coordinated actuation.',
    'Focused on repeatable strumming/fretting behavior in a short project window.',
  ]}
  how={[
    'Designed and assembled the mechanism around a real guitar platform.',
    'Iterated linkage/actuation placement for more consistent motion.',
  ]}
  results={[
    'Delivered a working setup with full rig and close-up strumming views documented.',
    'Established a baseline for future tuning and smoother performance.',
  ]}
/>
